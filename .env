# ================================
# MongoDB
# ================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=news_aggregator

# ================================
# Google Gemini AI
# ================================
# Dapatkan API key gratis di: https://aistudio.google.com/
GEMINI_API_KEY=AQ.Ab8RN6JVXE3DUKowrujwtT7LTLWRHjXU-RCfz2Ya4h6D5zrRQQ

# ================================
# Aplikasi
# ================================
APP_ENV=development
LOG_LEVEL=INFO

# URL frontend yang diizinkan mengakses API ini (CORS)
# Untuk multiple origins: ["http://localhost:3000","http://localhost:3001"]
CORS_ORIGINS=["http://localhost:3000"]

# ================================
# Scraper Settings
# ================================
# Delay (detik) antar HTTP request — jaga agar tidak terlalu kecil
SCRAPER_MIN_DELAY=1.0
SCRAPER_MAX_DELAY=3.0
SCRAPER_MAX_RETRIES=3
